---
const technologies = [
  { name: 'HTML5', icon: 'html5', color: '#E34F26', url: 'https://developer.mozilla.org/en-US/docs/Web/HTML' },
  { name: 'CSS3', icon: 'css3', color: '#1572B6', url: 'https://developer.mozilla.org/en-US/docs/Web/CSS' },
  { name: 'JavaScript', icon: 'javascript', color: '#F7DF1E', url: 'https://developer.mozilla.org/en-US/docs/Web/JavaScript' },
  { name: 'TypeScript', icon: 'typescript', color: '#3178C6', url: 'https://www.typescriptlang.org/' },
  { name: 'React', icon: 'react', color: '#61DAFB', url: 'https://react.dev/' },
  { name: 'Astro', icon: 'astro', color: '#FF5D01', url: 'https://astro.build/', invertDark: true },
  { name: 'TailwindCSS', icon: 'tailwindcss', color: '#06B6D4', url: 'https://tailwindcss.com/' },
  { name: 'Node.js', icon: 'nodejs', color: '#339933', url: 'https://nodejs.org/' },
  { name: 'Express', icon: 'express', color: '#FFFFFF', url: 'https://expressjs.com/', invertDark: true },
  { name: 'Socket.io', icon: 'socketio', color: '#010101', url: 'https://socket.io/', invertDark: true },
  { name: 'PostgreSQL', icon: 'postgresql', color: '#4169E1', url: 'https://www.postgresql.org/' },
];

const categories = [
  { title: 'Frontend', icon: 'M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5', techs: 'React, Astro, TailwindCSS' },
  { title: 'Backend', icon: 'M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7m0 0a3 3 0 01-3 3m0 3h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008zm-3 6h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008z', techs: 'Node.js, Express, Socket.io' },
  { title: 'Database', icon: 'M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125', techs: 'PostgreSQL' },
  { title: 'Languages', icon: 'M6.75 7.5l3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0021 18V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v12a2.25 2.25 0 002.25 2.25z', techs: 'TypeScript, JavaScript' },
];
---

<section id="tech" class="section-viewport relative overflow-hidden">
  <div class="section-divider"></div>

  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-[var(--gold-dark)] rounded-full blur-[200px] opacity-10 pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-6 w-full">
    <div class="section-reveal">
      <div class="flex items-center gap-4 mb-4">
        <span class="text-[var(--gold-glow)] font-mono text-xs tracking-[0.3em] uppercase">II</span>
        <div class="h-[1px] flex-1 bg-gradient-to-r from-[var(--gold)] to-transparent opacity-15"></div>
      </div>
      <div class="text-center mb-6">
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-2 tracking-tight" data-i18n="tech.title">
          Tech <span class="gradient-text">Stack</span>
        </h2>
        <p class="text-[var(--text-muted)] max-w-xl mx-auto italic" data-i18n="tech.subtitle">
          Tools of the craft, refined through the ages
        </p>
      </div>
    </div>

    <div class="section-reveal delay-200">
      <div class="flex flex-wrap justify-center gap-4 max-w-3xl mx-auto mb-8">
        {technologies.map((tech, i) => (
          <a
            href={tech.url}
            target="_blank"
            rel="noopener noreferrer"
            class="tech-icon group"
            data-tooltip={tech.name}
            data-invert-dark={tech.invertDark ? 'true' : undefined}
            style={`animation-delay: ${i * 0.05}s`}
          >
            <img
              src={`https://cdn.jsdelivr.net/gh/devicons/devicon/icons/${tech.icon}/${tech.icon}-original.svg`}
              alt={tech.name}
              class="w-9 h-9 transition-transform duration-300 group-hover:scale-110"
              loading="lazy"
              onerror="this.style.display='none'"
            />
          </a>
        ))}
      </div>
    </div>

    <div class="section-reveal delay-400">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 max-w-4xl mx-auto">
        {categories.map(cat => (
          <div class="glass-card holo-shimmer p-4 text-center group">
            <div class="w-12 h-12 mx-auto mb-3 bg-[var(--gold-dark)] border border-[var(--gold)] flex items-center justify-center group-hover:border-[var(--gold-light)] group-hover:shadow-[0_0_20px_var(--shadow-glow)] transition-all duration-300">
              <svg class="w-6 h-6 text-[var(--gold-glow)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={cat.icon} />
              </svg>
            </div>
            <h3 class="font-semibold text-[var(--text-primary)] mb-1 text-sm tracking-wider">{cat.title}</h3>
            <p class="text-[10px] text-[var(--text-muted)] font-mono tracking-wider">{cat.techs}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style is:global>
  [data-theme="dark"] [data-invert-dark="true"] img {
    filter: invert(1) brightness(1.5);
  }
</style>
